<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>LOCKET BU</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @keyframes emojiFly {
            0% { transform: translateY(0) scale(0.5); opacity: 1; }
            100% { transform: translateY(-500px) translateX(var(--x)) rotate(var(--r)); opacity: 0; scale: 2; }
        }
        .emoji {
            position: absolute; bottom: 120px; font-size: 50px;
            animation: emojiFly 2s ease-out forwards; pointer-events: none; z-index: 100;
        }
        .camera-box { border-radius: 55px; overflow: hidden; border: 4px solid #000; shadow: 0 20px 50px rgba(0,0,0,0.5); }
    </style>
</head>
<body class="bg-black text-white overflow-hidden">
    <div id="app" class="flex flex-col items-center h-screen bg-gradient-to-b from-[#3a0210] to-black">
        
        <div class="w-full max-w-md p-6 flex justify-between items-center">
            <div class="w-10 h-10 rounded-full bg-zinc-800 border-2 border-white/20"></div>
            <div class="bg-white/10 px-4 py-2 rounded-full text-xs font-bold">👤 63 người bạn</div>
            <div class="text-2xl">💬</div>
        </div>

        <div class="flex-1 w-full max-w-md flex flex-col items-center justify-center px-6 relative">
            <h1 class="absolute top-0 text-white/30 font-black tracking-widest text-[10px]">LOCKET BU</h1>
            
            <div class="relative w-full aspect-square bg-zinc-900 camera-box">
                <video id="video" autoplay playsinline class="w-full h-full object-cover scale-x-[-1]"></video>
                <div class="absolute top-5 left-5 text-white/50">⚡</div>
                <div class="absolute top-5 right-5 text-white/50 text-xs">1x</div>
            </div>

            <div id="emoji-layer"></div>
        </div>

        <div class="w-full max-w-md p-10 flex flex-col items-center gap-8">
            <div class="flex w-full justify-between items-center">
                <div class="text-3xl">🖼️</div>
                
                <button id="btn-shoot" class="w-20 h-20 bg-white rounded-full p-1 active:scale-90 transition">
                    <div class="w-full h-full rounded-full border-4 border-orange-500 bg-white"></div>
                </button>

                <div class="text-3xl">🔄</div>
            </div>

            <div class="flex flex-col items-center gap-1 opacity-80">
                <div class="bg-white/10 px-4 py-1.5 rounded-xl flex items-center gap-2">
                    <span class="bg-[#ff2d55] text-[10px] px-1 rounded">16</span>
                    <span class="text-sm font-bold">Lịch sử</span>
                </div>
                <div>▼</div>
            </div>
        </div>
    </div>

    <script>
        const video = document.getElementById('video');
        const btnShoot = document.getElementById('btn-shoot');
        const emojiLayer = document.getElementById('emoji-layer');

        // Mở Camera ngay lập tức
        navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' } })
            .then(stream => { video.srcObject = stream; })
            .catch(err => alert("Hãy cho phép quyền truy cập Camera nhé!"));

        // Click thả emoji
        btnShoot.onclick = () => {
            const emojis = ['❤️', '🔥', '😂', '😍', '✨', '💀'];
            const el = document.createElement('div');
            el.className = 'emoji';
            el.innerText = emojis[Math.floor(Math.random() * emojis.length)];
            el.style.setProperty('--x', (Math.random() * 300 - 150) + 'px');
            el.style.setProperty('--r', (Math.random() * 80 - 40) + 'deg');
            emojiLayer.appendChild(el);
            
            setTimeout(() => el.remove(), 2000);
        };
    </script>
</body>
</html>
