<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>LOCKET BU - CAPTURE</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @keyframes emojiFly {
            0% { transform: translateY(0) scale(0.5); opacity: 1; }
            100% { transform: translateY(-500px) translateX(var(--x)) rotate(var(--r)); opacity: 0; scale: 2; }
        }
        .emoji {
            position: absolute; bottom: 120px; font-size: 50px;
            animation: emojiFly 2s ease-out forwards; pointer-events: none; z-index: 100;
        }
        .camera-box { border-radius: 55px; overflow: hidden; border: 4px solid #000; position: relative; background: #111; }
        #photo-preview { display: none; width: 100%; height: 100%; object-cover: cover; position: absolute; top: 0; left: 0; z-index: 20; }
        .retake-btn { display: none; position: absolute; top: 20px; right: 20px; z-index: 30; background: rgba(0,0,0,0.5); padding: 8px; border-radius: 50%; }
    </style>
</head>
<body class="bg-black text-white overflow-hidden">
    <div id="app" class="flex flex-col items-center h-screen bg-gradient-to-b from-[#3a0210] to-black">
        
        <div class="w-full max-w-md p-6 flex justify-between items-center">
            <div class="w-10 h-10 rounded-full bg-zinc-800 border-2 border-white/20 overflow-hidden">
                <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Felix" />
            </div>
            <div class="bg-white/10 px-4 py-2 rounded-full text-xs font-bold border border-white/10">👤 63 người bạn</div>
            <div class="text-2xl">💬</div>
        </div>

        <div class="flex-1 w-full max-w-md flex flex-col items-center justify-center px-6 relative">
            <h1 class="absolute top-0 text-white/30 font-black tracking-widest text-[10px]">LOCKET BU</h1>
            
            <div class="relative w-full aspect-square camera-box shadow-2xl">
                <video id="video" autoplay playsinline class="w-full h-full object-cover scale-x-[-1]"></video>
                
                <img id="photo-preview" class="scale-x-[-1]" />
                
                <button id="btn-retake" class="retake-btn text-white font-bold">✕</button>

                <div class="absolute top-5 left-5 text-white/50 z-10">⚡</div>
                <div class="absolute top-5 right-12 text-white/50 text-xs z-10">1x</div>
            </div>

            <div id="emoji-layer"></div>
        </div>

        <div class="w-full max-w-md p-10 flex flex-col items-center gap-8">
            <div class="flex w-full justify-between items-center">
                <div class="text-3xl opacity-50">🖼️</div>
                
                <button id="btn-shoot" class="w-24 h-24 bg-white rounded-full p-1 active:scale-90 transition shadow-[0_0_20px_rgba(255,255,255,0.3)]">
                    <div class="w-full h-full rounded-full border-4 border-orange-500 bg-white"></div>
                </button>

                <div class="text-3xl opacity-50">🔄</div>
            </div>

            <div id="history-section" class="flex flex-col items-center gap-1 opacity-80 transition-all">
                <div class="bg-white/10 px-4 py-1.5 rounded-xl flex items-center gap-2 border border-white/5">
                    <span class="bg-[#ff2d55] text-[10px] px-1.5 py-0.5 rounded font-bold">16</span>
                    <span class="text-sm font-bold tracking-tight">Lịch sử</span>
                </div>
                <div class="animate-bounce mt-1">▼</div>
            </div>
            
            <button id="btn-send" class="hidden bg-yellow-400 text-black px-10 py-3 rounded-full font-black text-sm uppercase tracking-widest active:scale-95 transition">
                Gửi Locket
            </button>
        </div>
        
        <canvas id="canvas" style="display:none;"></canvas>
    </div>

    <script>
        const video = document.getElementById('video');
        const canvas = document.getElementById('canvas');
        const photoPreview = document.getElementById('photo-preview');
        const btnShoot = document.getElementById('btn-shoot');
        const btnRetake = document.getElementById('btn-retake');
        const btnSend = document.getElementById('btn-send');
        const historySection = document.getElementById('history-section');
        const emojiLayer = document.getElementById('emoji-layer');

        // 1. Mở Camera
        navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user', width: 500, height: 500 } })
            .then(stream => { video.srcObject = stream; })
            .catch(err => alert("Lỗi camera: " + err));

        // 2. Hàm thả Emoji
        function dropEmoji() {
            const emojis = ['❤️', '🔥', '😂', '😍', '✨', '💀', '👍'];
            const el = document.createElement('div');
            el.className = 'emoji';
            el.innerText = emojis[Math.floor(Math.random() * emojis.length)];
            el.style.setProperty('--x', (Math.random() * 300 - 150) + 'px');
            el.style.setProperty('--r', (Math.random() * 80 - 40) + 'deg');
            emojiLayer.appendChild(el);
            setTimeout(() => el.remove(), 2000);
        }

        // 3. Hàm Chụp Ảnh
        btnShoot.onclick = () => {
            // Hiệu ứng emoji trước
            dropEmoji();

            // Vẽ ảnh từ video vào canvas
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            canvas.getContext('2d').drawImage(video, 0, 0);
            
            // Chuyển canvas thành link ảnh
            const dataUrl = canvas.toDataURL('image/jpeg');
            photoPreview.src = dataUrl;
            
            // Hiển thị ảnh, ẩn video
            photoPreview.style.display = 'block';
            btnRetake.style.display = 'block';
            video.style.opacity = '0';
            
            // Đổi nút Lịch sử thành nút Gửi
            historySection.style.display = 'none';
            btnSend.style.display = 'block';
        };

        // 4. Chụp lại (Hủy ảnh cũ)
        btnRetake.onclick = (e) => {
            e.stopPropagation();
            photoPreview.style.display = 'none';
            btnRetake.style.display = 'none';
            video.style.opacity = '1';
            historySection.style.display = 'flex';
            btnSend.style.display = 'none';
        };

        // 5. Nút Gửi (Giả lập)
        btnSend.onclick = () => {
            alert("Đã gửi ảnh thành công lên LOCKET BU! ✨");
            btnRetake.click(); // Reset về màn hình chụp
        };
    </script>
</body>
</html>
